{
  "engine_id": "pqts-core-engine",
  "surfaces": [
    {
      "name": "studio-dashboard",
      "surface_type": "studio",
      "framework": "dash",
      "entrypoint": "src/dashboard/start.py",
      "consumes_control_plane": true,
      "active": true
    },
    {
      "name": "core-cli",
      "surface_type": "core",
      "framework": "python-cli",
      "entrypoint": "src/app/runtime.py",
      "consumes_control_plane": true,
      "active": true
    }
  ],
  "action_mappings": [
    {
      "action": "pause_trading",
      "ui_route": "/ops/pause",
      "cli_command": "pqts run --operator-tier pro",
      "api_endpoint": "/v1/operator/pause"
    },
    {
      "action": "kill_switch",
      "ui_route": "/ops/kill-switch",
      "cli_command": "python3 scripts/run_failure_drills.py",
      "api_endpoint": "/v1/admin/kill-switch"
    },
    {
      "action": "start_paper_campaign",
      "ui_route": "/campaigns/paper/start",
      "cli_command": "pqts paper start",
      "api_endpoint": "/v1/stream/start"
    }
  ]
}
